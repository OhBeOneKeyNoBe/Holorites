# Holorite model directories — these contain multi-GB tensor sidecars
# pulled from / shadowing existing HF models. Don't ship them in the repo.
Holorite-*/
*.pt
*.safetensors
*.bin
*.gguf
__pycache__/
*.pyc
.idea/
.vscode/
*.log

# Streamer asset trees — multi-GB chunked .npy outputs from chunkify_model().
# These are tests/data, not source. Keep them off the repo.
stream-*/
*.npy
